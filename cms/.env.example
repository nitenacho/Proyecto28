# Required for any deploy (rotate these for prod)
HOST=0.0.0.0
PORT=1337
APP_KEYS=replace_me_1,replace_me_2,replace_me_3,replace_me_4
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
JWT_SECRET=replace_me
ENCRYPTION_KEY=replace_me

# Database — dev defaults to sqlite, prod (Strapi Cloud) injects DATABASE_URL
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# When DATABASE_URL is present (Strapi Cloud / Railway / Render), it overrides
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Google OAuth Web Client ID used by /api/publish to verify id_tokens.
# Public identifier; keep it aligned with VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=644563573486-5pe2jvatetd46oke9ns8gskdt0jgsfi6.apps.googleusercontent.com

# Optional: if set, /api/publish sends a Discord webhook after each publish.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
